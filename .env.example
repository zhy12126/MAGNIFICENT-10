# 复制为 .env 后填入你自己的 Alpha Vantage Key。该文件不会被 Git 提交。
ALPHA_VANTAGE_API_KEY=
# 用于一次性从 SEC EDGAR + Stooq 免费回填五年历史估值。需包含真实联系邮箱。
SEC_EDGAR_USER_AGENT=Market10 your-email@example.com
# 可选：历史估值回填优先使用 EODHD 调整后日收盘价；未配置时使用 Stooq/Yahoo 免费回退。
EODHD_API_KEY=
# 可选：历史价格源。auto=优先 EODHD；stooq=强制免费 Stooq（无数据时回退 Yahoo）。
HISTORICAL_PRICE_SOURCE=auto
